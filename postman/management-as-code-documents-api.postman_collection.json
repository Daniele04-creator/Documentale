{
  "info": {
    "_postman_id": "1dcd2bcb-0e39-4bd1-a217-c7c0a2fd0185",
    "name": "Management as Code Documents API",
    "description": "Postman collection for the JavaScript NestJS documents API prototype.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Create manual document",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const response = pm.response.json();",
              "if (response.data && response.data.id) {",
              "  pm.collectionVariables.set('documentId', response.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Project plan\",\n  \"description\": \"Initial project document\",\n  \"origin\": \"manual\",\n  \"status\": \"draft\",\n  \"context\": {\n    \"projectId\": \"project-001\",\n    \"phaseId\": \"phase-analysis\",\n    \"substepId\": \"substep-requirements\",\n    \"wbsElementId\": \"wbs-001\"\n  },\n  \"metadata\": {\n    \"category\": \"planning\",\n    \"owner\": \"Daniele\"\n  },\n  \"fileInfo\": {\n    \"fileName\": \"project-plan.pdf\",\n    \"mimeType\": \"application/pdf\",\n    \"sizeBytes\": 123456\n  }\n}"
        },
        "url": "{{baseUrl}}/documents"
      }
    },
    {
      "name": "List documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?page=1&limit=10&projectId=project-001&origin=manual&status=draft&search=plan"
      }
    },
    {
      "name": "Get document by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "Update document",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated project plan\",\n  \"status\": \"in_review\",\n  \"metadata\": {\n    \"category\": \"planning\",\n    \"reviewRequired\": true\n  }\n}"
        },
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "Archive document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    }
  ]
}
