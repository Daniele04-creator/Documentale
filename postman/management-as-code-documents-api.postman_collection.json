          "raw": "{\n  \"title\": \"Project plan\",\n  \"description\": \"Initial project document\",\n  \"origin\": \"manual\",\n  \"status\": \"draft\",\n  \"context\": {\n    \"projectId\": \"project-001\",\n    \"phaseId\": \"phase-analysis\",\n    \"substepId\": \"substep-requirements\",\n    \"wbsElementId\": \"wbs-001\"\n  },\n  \"metadata\": {\n    \"category\": \"planning\",\n    \"owner\": \"Daniele\"\n  },\n  \"fileInfo\": {\n    \"fileName\": \"project-plan.pdf\",\n    \"mimeType\": \"application/pdf\",\n    \"sizeBytes\": 123456\n  }\n}"
