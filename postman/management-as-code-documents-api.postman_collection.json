{
  "info": {
    "_postman_id": "1dcd2bcb-0e39-4bd1-a217-c7c0a2fd0185",
    "name": "Management as Code Documents API",
    "description": "Postman collection for manually testing existing document records, JSONB filters, metadata updates, archiving, and local file download.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "11111111-1111-4111-8111-111111111111",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "02 List all documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents"
      }
    },
    {
      "name": "03 Search documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?search=plan"
      }
    },
    {
      "name": "04 Filter by projectId from context JSONB",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?projectId=project-001"
      }
    },
    {
      "name": "05 Filter by phaseId from context JSONB",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?phaseId=phase-analysis"
      }
    },
    {
      "name": "06 Filter by substepId from context JSONB",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?substepId=substep-requirements"
      }
    },
    {
      "name": "07 Filter by wbsElementId from context JSONB",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?wbsElementId=wbs-001"
      }
    },
    {
      "name": "08 Filter by taskId from context JSONB",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?taskId=task-001"
      }
    },
    {
      "name": "09 Filter by status",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents?status=draft"
      }
    },
    {
      "name": "10 Get document by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "11 Download document file",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}/file"
      }
    },
    {
      "name": "12 Update document metadata",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"in_review\",\n  \"metadata\": {\n    \"category\": \"planning\",\n    \"reviewRequired\": true\n  }\n}"
        },
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "13 Get document by id after update",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "14 Archive document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/documents/{{documentId}}"
      }
    },
    {
      "name": "15 Invalid id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 400', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/not-existing-document-id"
      }
    },
    {
      "name": "16 Missing valid UUID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/documents/00000000-0000-0000-0000-000000000000"
      }
    }
  ]
}
